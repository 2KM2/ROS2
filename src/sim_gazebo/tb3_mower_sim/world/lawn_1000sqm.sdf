<?xml version="1.0"?>
<sdf version="1.10">
  <world name="lawn_1000sqm">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <plugin name="gz::sim::systems::Physics" filename="gz-sim-physics-system"/>
    <plugin name="gz::sim::systems::UserCommands" filename="gz-sim-user-commands-system"/>
    <plugin name="gz::sim::systems::SceneBroadcaster" filename="gz-sim-scene-broadcaster-system"/>
    <plugin name="gz::sim::systems::Contact" filename="gz-sim-contact-system"/>
    <plugin name="gz::sim::systems::Sensors" filename="gz-sim-sensors-system">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin name="gz::sim::systems::Imu" filename="gz-sim-imu-system"/>

    <gravity>0 0 -9.8</gravity>
    <magnetic_field>5.5645e-06 2.28758e-05 -4.23884e-05</magnetic_field>
    <atmosphere type="adiabatic"/>

    <scene>
      <ambient>0.5 0.5 0.5 1</ambient>
      <background>0.55 0.75 0.95 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- Sun -->
    <light name="sun" type="directional">
      <pose>0 0 20 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1.0</intensity>
      <direction>-0.4 0.2 -0.9</direction>
      <diffuse>0.9 0.88 0.8 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>1000</range>
        <linear>0.005</linear>
        <constant>0.95</constant>
        <quadratic>0.0005</quadratic>
      </attenuation>
    </light>

    <!-- Ground plane (extends beyond the lawn) -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>80 60</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>80 60</size></plane></geometry>
          <material>
            <ambient>0.25 0.20 0.12 1</ambient>
            <diffuse>0.35 0.28 0.15 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!--
      Lawn area: 40 m x 25 m = 1000 m²
      Origin at center of lawn.
      Boundary fence height: 1.2 m (typical residential fence)
    -->
    <model name="lawn_1000sqm">
      <static>true</static>

      <!-- Grass floor 40m x 25m -->
      <link name="grass">
        <pose>0 0 0.025 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>40 25 0.05</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>40 25 0.05</size></box></geometry>
          <material>
            <ambient>0.10 0.32 0.06 1</ambient>
            <diffuse>0.15 0.50 0.10 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
      </link>

      <!-- ===== Boundary fence (wood style, 1.2m high, 0.1m thick) ===== -->
      <!-- North fence -->
      <link name="fence_north">
        <pose>0 12.55 0.6 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>40.2 0.1 1.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>40.2 0.1 1.2</size></box></geometry>
          <material>
            <ambient>0.45 0.30 0.15 1</ambient>
            <diffuse>0.60 0.40 0.20 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>

      <!-- South fence (split for 2m gate opening, centered) -->
      <link name="fence_south_left">
        <pose>-10.5 -12.55 0.6 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>19 0.1 1.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>19 0.1 1.2</size></box></geometry>
          <material>
            <ambient>0.45 0.30 0.15 1</ambient>
            <diffuse>0.60 0.40 0.20 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
      <link name="fence_south_right">
        <pose>10.5 -12.55 0.6 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>19 0.1 1.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>19 0.1 1.2</size></box></geometry>
          <material>
            <ambient>0.45 0.30 0.15 1</ambient>
            <diffuse>0.60 0.40 0.20 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>

      <!-- West fence -->
      <link name="fence_west">
        <pose>-20.05 0 0.6 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.1 25 1.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.1 25 1.2</size></box></geometry>
          <material>
            <ambient>0.45 0.30 0.15 1</ambient>
            <diffuse>0.60 0.40 0.20 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>

      <!-- East fence -->
      <link name="fence_east">
        <pose>20.05 0 0.6 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.1 25 1.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.1 25 1.2</size></box></geometry>
          <material>
            <ambient>0.45 0.30 0.15 1</ambient>
            <diffuse>0.60 0.40 0.20 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ===== Obstacles: Trees (cylindrical trunks + sphere canopy) ===== -->

    <!-- Tree 1: large oak, northwest area -->
    <model name="tree_1">
      <static>true</static>
      <link name="trunk">
        <pose>-12 8 0.75 0 0 0</pose>
        <collision name="collision">
          <geometry><cylinder><radius>0.2</radius><length>1.5</length></cylinder></geometry>
        </collision>
        <visual name="visual">
