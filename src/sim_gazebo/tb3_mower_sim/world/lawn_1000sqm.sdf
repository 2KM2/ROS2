          <geometry><cylinder><radius>0.05</radius><length>0.06</length></cylinder></geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.4 0.4 0.4 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ===== Fallen branch (temporary obstacle on grass) ===== -->
    <model name="fallen_branch">
      <static>true</static>
      <link name="branch">
        <pose>3 5 0.025 0 0 0.8</pose>
        <collision name="collision">
          <geometry><box><size>1.2 0.05 0.05</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.2 0.05 0.05</size></box></geometry>
          <material>
            <ambient>0.30 0.18 0.08 1</ambient>
            <diffuse>0.42 0.24 0.10 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ===== Child's toy (small random obstacle) ===== -->
    <model name="toy_ball">
      <static>true</static>
      <link name="ball">
        <pose>-3 1 0.08 0 0 0</pose>
        <collision name="collision">
          <geometry><sphere><radius>0.08</radius></sphere></geometry>
        </collision>
        <visual name="visual">
          <geometry><sphere><radius>0.08</radius></sphere></geometry>
          <material>
            <ambient>0.8 0.2 0.2 1</ambient>
            <diffuse>0.95 0.3 0.3 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ===== Lawn edge stones (border between grass and flower bed) ===== -->
    <model name="edge_stones">
      <static>true</static>
      <link name="stones">
        <pose>0 3.5 0.04 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>3.0 0.12 0.08</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>3.0 0.12 0.08</size></box></geometry>
          <material>
            <ambient>0.5 0.48 0.44 1</ambient>
            <diffuse>0.62 0.60 0.55 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
