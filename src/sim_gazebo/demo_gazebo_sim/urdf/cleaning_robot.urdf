<?xml version="1.0"?>
<!--
  Differential-drive cleaning robot for ROS 2 and Gazebo Harmonic.

  Dimensions:
    body diameter: 0.34 m
    body height:   0.07 m
    wheel radius:  0.035 m
    wheel spacing: 0.33 m
-->
<robot name="cleaning_robot">
  <material name="body_blue">
    <color rgba="0.08 0.32 0.72 1"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.08 0.08 0.08 1"/>
  </material>
  <material name="lidar_black">
    <color rgba="0.02 0.02 0.02 1"/>
  </material>

  <!-- Navigation reference frame located on the floor. -->
  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia
        ixx="0.03817" ixy="0" ixz="0"
        iyy="0.03817" iyz="0"
        izz="0.07225"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.17" length="0.07"/>
      </geometry>
      <material name="body_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.17" length="0.07"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
  </joint>

  <link name="left_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.15"/>
      <inertia
        ixx="0.00005375" ixy="0" ixz="0"
        iyy="0.00005375" iyz="0"
        izz="0.00009188"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.025"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0.025 0.165 -0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.01"/>
  </joint>

  <link name="right_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.15"/>
      <inertia
        ixx="0.00005375" ixy="0" ixz="0"
        iyy="0.00005375" iyz="0"
        izz="0.00009188"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.025"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0.025 -0.165 -0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.01"/>
  </joint>

  <!-- A low-friction rear support approximates the freely rotating caster. -->
  <link name="caster_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia
        ixx="0.00000648" ixy="0" ixz="0"
        iyy="0.00000648" iyz="0"
        izz="0.00000648"/>
    </inertial>
    <visual>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
    </collision>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.115 0 -0.057" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.08"/>
      <inertia
        ixx="0.000038" ixy="0" ixz="0"
        iyy="0.000038" iyz="0"
        izz="0.000064"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
      <material name="lidar_black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo appearance and contact properties. -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="caster_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.02</mu1>
    <mu2>0.02</mu2>
  </gazebo>
  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
    <sensor name="laser_scan" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>false</visualize>
      <topic>scan</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
          <vertical>
            <samples>24</samples>
            <resolution>1</resolution>
            <min_angle>-0.26179939</min_angle>
            <max_angle>0.26179939</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>
  <gazebo reference="lidar_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <!-- Gazebo Harmonic systems used after spawning this URDF. -->
  <gazebo>
    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.33</wheel_separation>
      <wheel_radius>0.035</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
      <max_linear_velocity>0.5</max_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <max_linear_acceleration>0.8</max_linear_acceleration>
      <max_angular_acceleration>3.0</max_angular_acceleration>
    </plugin>
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>
</robot>
