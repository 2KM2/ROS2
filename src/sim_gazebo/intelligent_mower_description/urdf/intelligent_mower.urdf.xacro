<?xml version="1.0"?>
<robot name="intelligent_mower" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- SI units. The design is a compact, four-wheel skid-steer mower. -->
  <xacro:property name="mower_pi" value="3.141592653589793"/>
  <xacro:property name="wheel_radius" value="0.16"/>
  <xacro:property name="wheel_width" value="0.07"/>
  <xacro:property name="track" value="0.48"/>
  <xacro:property name="wheelbase" value="0.58"/>

  <material name="shell"><color rgba="0.05 0.20 0.80 1"/></material>
  <material name="tyre"><color rgba="0.03 0.03 0.03 1"/></material>
  <material name="safety"><color rgba="0.95 0.55 0.02 1"/></material>
  <material name="sensor"><color rgba="0.75 0.75 0.78 1"/></material>

  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial><mass value="${mass}"/><inertia ixx="${mass * (y*y + z*z) / 12}" ixy="0" ixz="0" iyy="${mass * (x*x + z*z) / 12}" iyz="0" izz="${mass * (x*x + y*y) / 12}"/></inertial>
  </xacro:macro>
  <xacro:macro name="wheel" params="name">
    <link name="${name}">
      <inertial><origin rpy="${mower_pi/2} 0 0"/><mass value="0.65"/><inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.006"/></inertial>
      <visual><origin rpy="${mower_pi/2} 0 0"/><geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry><material name="tyre"/></visual>
      <collision><origin rpy="${mower_pi/2} 0 0"/><geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry></collision>
    </link>
  </xacro:macro>

  <link name="base_footprint"/>
  <link name="base_link">
    <xacro:box_inertia mass="18.0" x="0.78" y="0.62" z="0.25"/>
    <visual><origin xyz="0 0 0.27"/><geometry><box size="0.78 0.62 0.25"/></geometry><material name="shell"/></visual>
    <collision><origin xyz="0 0 0.27"/><geometry><box size="0.78 0.62 0.25"/></geometry></collision>
  </link>
  <joint name="base_footprint_joint" type="fixed"><parent link="base_footprint"/><child link="base_link"/><origin xyz="0 0 0.02"/></joint>

  <xacro:wheel name="front_left_wheel_link"/>
  <joint name="front_left_wheel_joint" type="continuous"><parent link="base_link"/><child link="front_left_wheel_link"/><origin xyz="${wheelbase/2} ${track/2} ${wheel_radius}"/><axis xyz="0 1 0"/></joint>
  <xacro:wheel name="front_right_wheel_link"/>
  <joint name="front_right_wheel_joint" type="continuous"><parent link="base_link"/><child link="front_right_wheel_link"/><origin xyz="${wheelbase/2} -${track/2} ${wheel_radius}"/><axis xyz="0 1 0"/></joint>
  <xacro:wheel name="rear_left_wheel_link"/>
  <joint name="rear_left_wheel_joint" type="continuous"><parent link="base_link"/><child link="rear_left_wheel_link"/><origin xyz="-${wheelbase/2} ${track/2} ${wheel_radius}"/><axis xyz="0 1 0"/></joint>
  <xacro:wheel name="rear_right_wheel_link"/>
  <joint name="rear_right_wheel_joint" type="continuous"><parent link="base_link"/><child link="rear_right_wheel_link"/><origin xyz="-${wheelbase/2} -${track/2} ${wheel_radius}"/><axis xyz="0 1 0"/></joint>

  <!-- The deck collision is separate from the visual blade, so the blade can be controlled safely later. -->
  <link name="cutter_deck_link">
    <xacro:box_inertia mass="3.0" x="0.52" y="0.52" z="0.06"/>
    <visual><geometry><cylinder radius="0.26" length="0.06"/></geometry><material name="tyre"/></visual>
    <collision><geometry><cylinder radius="0.26" length="0.06"/></geometry></collision>
  </link>
  <joint name="cutter_deck_joint" type="fixed"><parent link="base_link"/><child link="cutter_deck_link"/><origin xyz="0 0 0.13"/></joint>
  <link name="cutter_blade_link"><visual><geometry><cylinder radius="0.20" length="0.01"/></geometry><material name="safety"/></visual></link>
  <joint name="cutter_blade_joint" type="continuous"><parent link="cutter_deck_link"/><child link="cutter_blade_link"/><origin xyz="0 0 -0.04"/><axis xyz="0 0 1"/></joint>

  <!-- Bumper gives perception/control software a frame for a contact sensor or safety zone. -->
  <link name="bumper_link"><xacro:box_inertia mass="0.25" x="0.05" y="0.55" z="0.10"/><visual><geometry><box size="0.05 0.55 0.10"/></geometry><material name="safety"/></visual><collision><geometry><box size="0.05 0.55 0.10"/></geometry></collision></link>
  <joint name="bumper_joint" type="fixed"><parent link="base_link"/><child link="bumper_link"/><origin xyz="0.415 0 0.20"/></joint>

  <link name="lidar_link"><xacro:box_inertia mass="0.15" x="0.08" y="0.08" z="0.05"/><visual><geometry><cylinder radius="0.04" length="0.05"/></geometry><material name="sensor"/></visual></link>
  <joint name="lidar_joint" type="fixed"><parent link="base_link"/><child link="lidar_link"/><origin xyz="0.15 0 0.47"/></joint>
  <link name="camera_link"><xacro:box_inertia mass="0.10" x="0.04" y="0.06" z="0.05"/><visual><geometry><box size="0.04 0.06 0.05"/></geometry><material name="sensor"/></visual></link>
  <joint name="camera_joint" type="fixed"><parent link="base_link"/><child link="camera_link"/><origin xyz="0.40 0 0.36"/></joint>
  <link name="imu_link"><xacro:box_inertia mass="0.04" x="0.03" y="0.02" z="0.01"/><visual><geometry><box size="0.03 0.02 0.01"/></geometry><material name="sensor"/></visual></link>
  <joint name="imu_joint" type="fixed"><parent link="base_link"/><child link="imu_link"/><origin xyz="0 0 0.39"/></joint>
  <!-- This is a frame only: Gazebo does not synthesize satellite measurements. -->
  <link name="gnss_antenna_link"><visual><geometry><cylinder radius="0.045" length="0.025"/></geometry><material name="sensor"/></visual></link>
  <joint name="gnss_antenna_joint" type="fixed"><parent link="base_link"/><child link="gnss_antenna_link"/><origin xyz="-0.12 0 0.48"/></joint>
  <link name="charging_contact_link"><visual><geometry><box size="0.03 0.20 0.04"/></geometry><material name="safety"/></visual></link>
  <joint name="charging_contact_joint" type="fixed"><parent link="base_link"/><child link="charging_contact_link"/><origin xyz="-0.405 0 0.18"/></joint>

  <gazebo reference="lidar_link"><sensor name="lidar" type="gpu_lidar"><always_on>true</always_on><update_rate>15</update_rate><topic>/intelligent_mower/scan</topic><lidar><scan><horizontal><samples>720</samples><resolution>1</resolution><min_angle>-${mower_pi}</min_angle><max_angle>${mower_pi}</max_angle></horizontal></scan><range><min>0.10</min><max>20.0</max><resolution>0.02</resolution></range></lidar></sensor></gazebo>
  <gazebo reference="camera_link"><sensor name="front_camera" type="camera"><always_on>true</always_on><update_rate>15</update_rate><topic>/intelligent_mower/camera/image</topic><camera><horizontal_fov>1.396</horizontal_fov><image><width>640</width><height>480</height><format>R8G8B8</format></image><clip><near>0.05</near><far>20</far></clip></camera></sensor></gazebo>
  <gazebo reference="imu_link"><sensor name="imu" type="imu"><always_on>true</always_on><update_rate>100</update_rate><topic>/intelligent_mower/imu</topic></sensor></gazebo>
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint><left_joint>rear_left_wheel_joint</left_joint><right_joint>front_right_wheel_joint</right_joint><right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>${track}</wheel_separation><wheel_radius>${wheel_radius}</wheel_radius><topic>/intelligent_mower/cmd_vel</topic><odom_topic>/intelligent_mower/odom</odom_topic><tf_topic>/intelligent_mower/tf</tf_topic><frame_id>odom</frame_id><child_frame_id>base_footprint</child_frame_id><odom_publish_frequency>30</odom_publish_frequency><min_velocity>-0.6</min_velocity><max_velocity>0.6</max_velocity>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"><topic>/intelligent_mower/joint_states</topic></plugin>
  </gazebo>
</robot>
